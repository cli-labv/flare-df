# ═══════════════════════════════════════════════════════════════════════════════
# 🔥 FLARE-DF - Configuración de Entorno
# ═══════════════════════════════════════════════════════════════════════════════
# 
# Instrucciones:
# 1. Copia este archivo a .env: cp .env.example .env
# 2. Configura los valores según tus necesidades
# 3. NUNCA commitees el archivo .env (contiene información sensible)
# 
# ═══════════════════════════════════════════════════════════════════════════════

# ┌───────────────────────────────────────────────────────────────────────────┐
# │ PERMISOS DEL SISTEMA                                                      │
# └───────────────────────────────────────────────────────────────────────────┘
# Contraseña sudo para gestión automática de permisos
# Si no se configura, la aplicación la pedirá al iniciar
# 
# ⚠️  IMPORTANTE: Este archivo NO debe ser commiteado a git
# El .gitignore ya lo excluye por seguridad
SUDO_PASSWORD=

# ┌───────────────────────────────────────────────────────────────────────────┐
# │ PROCESAMIENTO PARALELO                                                    │
# └───────────────────────────────────────────────────────────────────────────┘
# Número de workers para procesamiento paralelo
# Por defecto: cpu_count() - 1 (deja un núcleo libre)
# 
# Ejemplos:
#   MAX_WORKERS=4   # Usa 4 workers fijos
#   MAX_WORKERS=8   # Usa 8 workers fijos
# 
# Descomenta para configurar manualmente:
# MAX_WORKERS=

# ┌───────────────────────────────────────────────────────────────────────────┐
# │ MODO DEBUG                                                                │
# └───────────────────────────────────────────────────────────────────────────┘
# Habilita salida de debug adicional
# Útil para desarrollo y diagnóstico de problemas
# 
# Valores: true | false
# Por defecto: false
DEBUG=false

# ┌───────────────────────────────────────────────────────────────────────────┐
# │ RUTAS PERSONALIZADAS (Opcional)                                          │
# └───────────────────────────────────────────────────────────────────────────┘
# Puedes especificar rutas personalizadas para entrada/salida
# Si no se configuran, se usan las carpetas por defecto del proyecto
# 
# INPUT_DIR=./input
# OUTPUT_DIR=./output
# TEMP_DIR=./temp

# ═══════════════════════════════════════════════════════════════════════════════
# 🔥 Fin de configuración
# ═══════════════════════════════════════════════════════════════════════════════

