# ═══════════════════════════════════════════════════════════════════════════════
# FLARE-DF - Configuración de entorno
# ═══════════════════════════════════════════════════════════════════════════════
# Copia este archivo a .env y configura tus valores

# Contraseña sudo para permisos de escritura (opcional)
# Si no se proporciona, se pedirá por CLI
SUDO_PASSWORD=

# Número de workers para procesamiento paralelo (opcional)
# Por defecto usa num_cpus - 1
# MAX_WORKERS=4

# Habilitar modo debug (opcional)
# DEBUG=false
