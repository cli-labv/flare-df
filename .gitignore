# ============================================
# 🔥 FLARE-DF - Git Ignore Configuration
# ============================================

# ==================== Rust Build ====================
/target/
Cargo.lock
*.rlib
*.rmeta

# ==================== IDE & Editors ====================
.idea/
.vscode/
*.swp
*.swo
*~
.vim/
.project
.settings/
*.sublime-*

# ==================== Environment & Secrets ====================
.env
.env.local
.env.*.local

# ==================== Temporary Files ====================
temp/
*.tmp
*.bak
*.cache
*.lock

# ==================== Output & Input PDFs ====================
# Archivos PDF procesados
output/*.pdf
output/**/*.pdf

# Archivos PDF originales (opcional)
input/*.pdf
input/**/*.pdf

# Mantener las carpetas vacías
!input/.gitkeep
!output/.gitkeep
!temp/.gitkeep

# ==================== System Files ====================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ==================== Logs ====================
*.log
logs/
*.log.*

# ==================== Documentation Artifacts ====================
# Mantener SPINNERS.md y otros docs importantes
!SPINNERS.md
!README.md
!docs/

# ==================== Test Artifacts ====================
*.profraw
*.profdata

# ==================== Backup Files ====================
*.orig
*.rej
*~.nib

# ==================== Compressed Archives ====================
*.zip
*.tar.gz
*.rar
*.7z
!examples/*.zip
